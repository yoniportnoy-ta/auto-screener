# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
PORT=8000

# Shared secret used to authenticate calls to the screener's mutation endpoints.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SCREENER_API_TOKEN=changeme

# ─── Database ────────────────────────────────────────────────────────────────
# Render injects this automatically when the Postgres add-on is attached.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Comeet — public API (api.comeet.co, JWT auth) ───────────────────────────
COMEET_API_KEY=
COMEET_API_SECRET=

# ─── Comeet — internal API (app.comeet.co, cookie auth) ──────────────────────
# Use a SEPARATE low-permission user from the referral bot — same Comeet
# tenant only allows one active session per user, and we don't want
# screener login attempts to invalidate the referral bot's cached session.
COMEET_APP_EMAIL=
COMEET_APP_PASSWORD=

# 2captcha API key for solving the reCAPTCHA on /signin.
CAPTCHA_API_KEY=

# ─── Anthropic Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── Optional Google integration (only if you keep Sheets as a read mirror) ──
# GOOGLE_SERVICE_ACCOUNT_JSON=
# FEEDBACK_SHEET_ID=

# ─── Scoring tuning ──────────────────────────────────────────────────────────
SCORING_USE_V2=1
NOTE_RATING_THRESHOLD=3
AUTO_TAG_ENABLED=0           # flip to 1 once the internal API is verified
TAG_RATING_THRESHOLD=3       # only tag candidates rated >= this
SCREENER_MAX_PER_RUN=20
SCREENER_STEP_SUBSTRINGS=cv screen / recruiter
EXCLUDED_RECRUITING_STATUSES=Rejected,Withdrawn,Hired
